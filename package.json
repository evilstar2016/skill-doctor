{
  "name": "@evilstar2025/skill-doctor",
  "version": "0.3.5",
  "description": "Local CLI for auditing AI agent skills, conflicts, duplicates, and safety risks.",
  "keywords": [
    "ai-agent",
    "agent-skills",
    "claude-code",
    "codex",
    "cursor",
    "github-copilot",
    "developer-tools",
    "cli",
    "security",
    "audit"
  ],
  "type": "module",
  "bin": {
    "skill-doctor": "dist/index.cjs"
  },
  "files": [
    "dist",
    "assets",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "ROADMAP.md",
    "UI_TECHNICAL_PLAN.zh-CN.md",
    "CONTRIBUTING.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evilstar2016/skill-doctor.git"
  },
  "homepage": "https://github.com/evilstar2016/skill-doctor#readme",
  "bugs": {
    "url": "https://github.com/evilstar2016/skill-doctor/issues"
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:ui",
    "build:cli": "tsup",
    "build:ui": "vite build --config web/vite.config.ts",
    "dev": "tsx src/cli/index.ts",
    "dev:ui": "vite --config web/vite.config.ts",
    "typecheck:ui": "tsc -p web/tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:scenarios": "tsx scripts/testing/run-feature-scenarios.ts",
    "verify:feature": "npm test && npm run test:scenarios --"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.28.1",
    "jsdom": "^25.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.3.6",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
